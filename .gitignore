# ==========================================
# Professional Full-Stack Git Ignore Rules
# ==========================================

# --- System Files ---
.DS_Store
Thumbs.db
*.local

# --- Python / Django Caches & Virtual Envs ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.ipynb_checkpoints
*.sqlite3
venv/
.venv/
ENV/
env.bak/
venv.bak/
backend/venv/
backend/.venv/

# --- NodeJS / React / Vite builds ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.next/
frontend/out/

# --- Environment Secrets (CRITICAL for Security) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env

# --- IDEs, Editors & Tooling Caches ---
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.eslintcache
.parcel-cache
.cache/
.vite/

# --- Machine Learning Assets ---
# Weight binaries are kept locally or pulled from secure storage/LFS
*.pt
*.onnx
*.pkl
*.joblib
backend/apps/ml_models/ml/trained_models/*
!backend/apps/ml_models/ml/trained_models/.gitkeep
